{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/Xiddoc/rosetta-maps/schema/rosetta-map.schema.json",
    "title": "Rosetta map (schema_version 2)",
    "description": "Canonical, language-neutral schema for the `schema_version: 2` map format. This repo (rosetta-maps) OWNS this schema: it is the single source of truth for the format that the maps here are stored in, and the rosetta-frida (TS/Zod) and rosetta-xposed (Kotlin) adapters are clients that must track it. CI validates every map against this file; editors can point at it for autocompletion. Changing the format means bumping this schema first, then updating the client adapters.",
    "type": "object",
    "required": ["schema_version", "app", "version", "version_code", "classes"],
    "properties": {
        "schema_version": { "const": 2 },
        "app": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z0-9_]+)+$"
        },
        "version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "version_code": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "captured_at": { "type": "string", "maxLength": 4096 },
        "signer_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "frida_min_version": { "type": "string", "maxLength": 4096 },
        "frida_max_version": { "type": "string", "maxLength": 4096 },
        "sources": {
            "type": "array",
            "maxItems": 100,
            "items": { "$ref": "#/definitions/mapSource" }
        },
        "classes": {
            "type": "object",
            "maxProperties": 50000,
            "propertyNames": { "not": { "enum": ["__proto__", "constructor", "prototype"] } },
            "additionalProperties": { "$ref": "#/definitions/classEntry" }
        }
    },
    "definitions": {
        "confidence": { "enum": ["high", "medium", "low"] },
        "classKind": {
            "enum": [
                "class",
                "interface",
                "enum",
                "aidl_stub",
                "aidl_callback",
                "synthetic",
                "anonymous"
            ]
        },
        "mapSource": {
            "type": "object",
            "required": ["tool"],
            "properties": {
                "tool": { "type": "string", "minLength": 1, "maxLength": 4096 },
                "config": { "type": "string", "maxLength": 4096 },
                "classes": { "type": "integer" },
                "notes": { "type": "string", "maxLength": 4096 },
                "confidence": { "$ref": "#/definitions/confidence" }
            }
        },
        "methodEntry": {
            "type": "object",
            "required": ["obfuscated", "signature"],
            "properties": {
                "obfuscated": { "type": "string", "minLength": 1, "maxLength": 512 },
                "signature": { "type": "string", "minLength": 1, "maxLength": 4096 },
                "aidl_txn": { "type": "integer" },
                "static": { "type": "boolean" },
                "synthetic": { "type": "boolean" },
                "is_constructor": { "type": "boolean" }
            }
        },
        "methodMapValue": {
            "oneOf": [
                { "$ref": "#/definitions/methodEntry" },
                {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 200,
                    "items": { "$ref": "#/definitions/methodEntry" }
                }
            ]
        },
        "fieldEntry": {
            "type": "object",
            "required": ["obfuscated", "type"],
            "properties": {
                "obfuscated": { "type": "string", "minLength": 1, "maxLength": 512 },
                "type": { "type": "string", "minLength": 1, "maxLength": 4096 },
                "static": { "type": "boolean" }
            }
        },
        "classEntry": {
            "type": "object",
            "required": ["obfuscated"],
            "properties": {
                "obfuscated": { "type": "string", "minLength": 1, "maxLength": 512 },
                "extends": { "type": "string", "maxLength": 4096 },
                "kind": { "$ref": "#/definitions/classKind" },
                "dex": { "type": "string", "maxLength": 4096 },
                "aidl_descriptor": { "type": "string", "maxLength": 4096 },
                "anchors": {
                    "type": "array",
                    "maxItems": 1000,
                    "items": { "type": "string", "maxLength": 4096 }
                },
                "methods": {
                    "type": "object",
                    "maxProperties": 5000,
                    "propertyNames": { "not": { "enum": ["__proto__", "constructor", "prototype"] } },
                    "additionalProperties": { "$ref": "#/definitions/methodMapValue" }
                },
                "fields": {
                    "type": "object",
                    "maxProperties": 5000,
                    "propertyNames": { "not": { "enum": ["__proto__", "constructor", "prototype"] } },
                    "additionalProperties": { "$ref": "#/definitions/fieldEntry" }
                },
                "source": { "type": "string", "maxLength": 4096 },
                "confidence": { "$ref": "#/definitions/confidence" }
            }
        }
    }
}
