{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/Xiddoc/rosetta-maps/schema/migration-samples/v2-to-v3/frozen-v2.schema.json",
    "title": "FROZEN Rosetta map (schema_version 2) \u2014 migration fixture only",
    "description": "NOT the canonical schema. A FROZEN copy of the previous schema_version:2 canonical schema, kept ONLY so the worked 2->3 migration example stays CI-checkable after the live canonical schema was bumped to v3. The before.v2.json fixture validates against THIS; the migrated after.v3.json validates against the live canonical (now v3) schema. Do not consume this as a real schema.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "app",
        "version",
        "version_code",
        "classes"
    ],
    "properties": {
        "schema_version": {
            "const": 2
        },
        "app": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)+$"
        },
        "version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "\\S",
            "description": "Human-readable versionName label / fuzzy fallback only. Must contain a non-whitespace character (a whitespace-only label is rejected); version_code is the authoritative selection key."
        },
        "version_code": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991,
            "description": "Full Android longVersionCode ((versionCodeMajor << 32) | versionCode), never masked. Capped at Number.MAX_SAFE_INTEGER (2^53 - 1) so the Frida JS client can represent it exactly."
        },
        "captured_at": {
            "type": "string",
            "maxLength": 4096
        },
        "signer_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "Canonical on-disk form: lowercase hex, NO colon separators, exactly 64 hex chars (the SHA-256 of the signing certificate). Clients enforce this fail-closed; a wrong-case or colon-separated value is rejected here."
        },
        "client_hints": {
            "type": "object",
            "additionalProperties": false,
            "description": "Optional, advisory hints for specific clients. NOT used by the core resolver; a client MAY consult them. Keeping them in a sub-object keeps the top-level identity keys clean and signals they are non-authoritative.",
            "properties": {
                "frida_min_version": {
                    "type": "string",
                    "maxLength": 4096
                },
                "frida_max_version": {
                    "type": "string",
                    "maxLength": 4096
                }
            }
        },
        "sources": {
            "type": "array",
            "maxItems": 100,
            "items": {
                "$ref": "#/definitions/mapSource"
            }
        },
        "classes": {
            "type": "object",
            "maxProperties": 50000,
            "propertyNames": {
                "not": {
                    "enum": [
                        "__proto__",
                        "constructor",
                        "prototype"
                    ]
                }
            },
            "additionalProperties": {
                "$ref": "#/definitions/classEntry"
            }
        }
    },
    "definitions": {
        "confidence": {
            "enum": [
                "high",
                "medium",
                "low"
            ]
        },
        "classKind": {
            "enum": [
                "class",
                "interface",
                "enum",
                "aidl_stub",
                "aidl_callback",
                "synthetic",
                "anonymous"
            ]
        },
        "mapSource": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "tool"
            ],
            "properties": {
                "tool": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 4096,
                    "description": "Provenance of these entries. The canonical, client-neutral vocabulary is `sigmatcher`, `hand-authored`, and `rosetta-runtime-discovered` (the runtime-discovery token is framework-neutral on purpose \u2014 do NOT use a framework-specific spelling like `rosetta-frida-runtime-discovered`). Free-form values are permitted for other tools.",
                    "examples": [
                        "sigmatcher",
                        "hand-authored",
                        "rosetta-runtime-discovered"
                    ]
                },
                "config": {
                    "type": "string",
                    "maxLength": 4096
                },
                "classes": {
                    "type": "integer",
                    "minimum": 0
                },
                "notes": {
                    "type": "string",
                    "maxLength": 4096
                },
                "confidence": {
                    "$ref": "#/definitions/confidence"
                }
            }
        },
        "methodEntry": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "obfuscated",
                "signature"
            ],
            "properties": {
                "obfuscated": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                },
                "signature": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 4096
                },
                "aidl_txn": {
                    "type": "integer"
                },
                "static": {
                    "type": "boolean"
                },
                "synthetic": {
                    "type": "boolean"
                },
                "is_constructor": {
                    "type": "boolean"
                }
            }
        },
        "methodMapValue": {
            "oneOf": [
                {
                    "$ref": "#/definitions/methodEntry"
                },
                {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 200,
                    "items": {
                        "$ref": "#/definitions/methodEntry"
                    }
                }
            ]
        },
        "fieldEntry": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "obfuscated",
                "type"
            ],
            "properties": {
                "obfuscated": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                },
                "type": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 4096
                },
                "static": {
                    "type": "boolean"
                }
            }
        },
        "classEntry": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "obfuscated"
            ],
            "properties": {
                "obfuscated": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                },
                "extends": {
                    "type": "string",
                    "maxLength": 4096
                },
                "kind": {
                    "$ref": "#/definitions/classKind"
                },
                "dex": {
                    "type": "string",
                    "maxLength": 4096
                },
                "aidl_descriptor": {
                    "type": "string",
                    "maxLength": 4096
                },
                "anchors": {
                    "type": "array",
                    "maxItems": 1000,
                    "items": {
                        "type": "string",
                        "maxLength": 4096
                    }
                },
                "methods": {
                    "type": "object",
                    "maxProperties": 5000,
                    "propertyNames": {
                        "not": {
                            "enum": [
                                "__proto__",
                                "constructor",
                                "prototype"
                            ]
                        }
                    },
                    "additionalProperties": {
                        "$ref": "#/definitions/methodMapValue"
                    }
                },
                "fields": {
                    "type": "object",
                    "maxProperties": 5000,
                    "propertyNames": {
                        "not": {
                            "enum": [
                                "__proto__",
                                "constructor",
                                "prototype"
                            ]
                        }
                    },
                    "additionalProperties": {
                        "$ref": "#/definitions/fieldEntry"
                    }
                },
                "source": {
                    "type": "string",
                    "maxLength": 4096
                },
                "confidence": {
                    "$ref": "#/definitions/confidence"
                }
            }
        }
    }
}
