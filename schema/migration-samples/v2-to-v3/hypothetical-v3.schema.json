{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/Xiddoc/rosetta-maps/schema/migration-samples/v2-to-v3/hypothetical-v3.schema.json",
    "title": "HYPOTHETICAL Rosetta map (schema_version 3) — fixture only",
    "description": "NOT the canonical schema. This is an ILLUSTRATIVE schema_version:3 schema that exists ONLY to make the worked 2->3 migration example in docs/reference/schema-migration.md checkable in CI. The single difference from the live schema_version:2 schema is the hard gate (const 3) and that the human label `version` becomes a structured object `{ name: string }`. The canonical schema (schema/rosetta-map.schema.json) remains schema_version:2; do not consume this file as a real schema.",
    "type": "object",
    "additionalProperties": false,
    "required": ["schema_version", "app", "version", "version_code", "classes"],
    "properties": {
        "schema_version": { "const": 3 },
        "app": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)+$"
        },
        "version": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "description": "v3 change: the human-readable versionName label, now a structured object instead of a bare string. version_code remains the authoritative selection key.",
            "properties": {
                "name": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "\\S" }
            }
        },
        "version_code": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "captured_at": { "type": "string", "maxLength": 4096 },
        "signer_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "client_hints": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "frida_min_version": { "type": "string", "maxLength": 4096 },
                "frida_max_version": { "type": "string", "maxLength": 4096 }
            }
        },
        "sources": {
            "type": "array",
            "maxItems": 100,
            "items": { "$ref": "#/definitions/mapSource" }
        },
        "classes": {
            "type": "object",
            "maxProperties": 50000,
            "propertyNames": { "not": { "enum": ["__proto__", "constructor", "prototype"] } },
            "additionalProperties": { "$ref": "#/definitions/classEntry" }
        }
    },
    "definitions": {
        "confidence": { "enum": ["high", "medium", "low"] },
        "classKind": {
            "enum": [
                "class",
                "interface",
                "enum",
                "aidl_stub",
                "aidl_callback",
                "synthetic",
                "anonymous"
            ]
        },
        "mapSource": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tool"],
            "properties": {
                "tool": { "type": "string", "minLength": 1, "maxLength": 4096 },
                "config": { "type": "string", "maxLength": 4096 },
                "classes": { "type": "integer", "minimum": 0 },
                "notes": { "type": "string", "maxLength": 4096 },
                "confidence": { "$ref": "#/definitions/confidence" }
            }
        },
        "methodEntry": {
            "type": "object",
            "additionalProperties": false,
            "required": ["obfuscated", "signature"],
            "properties": {
                "obfuscated": { "type": "string", "minLength": 1, "maxLength": 512 },
                "signature": { "type": "string", "minLength": 1, "maxLength": 4096 },
                "aidl_txn": { "type": "integer" },
                "static": { "type": "boolean" },
                "synthetic": { "type": "boolean" },
                "is_constructor": { "type": "boolean" }
            }
        },
        "methodMapValue": {
            "oneOf": [
                { "$ref": "#/definitions/methodEntry" },
                {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 200,
                    "items": { "$ref": "#/definitions/methodEntry" }
                }
            ]
        },
        "fieldEntry": {
            "type": "object",
            "additionalProperties": false,
            "required": ["obfuscated", "type"],
            "properties": {
                "obfuscated": { "type": "string", "minLength": 1, "maxLength": 512 },
                "type": { "type": "string", "minLength": 1, "maxLength": 4096 },
                "static": { "type": "boolean" }
            }
        },
        "classEntry": {
            "type": "object",
            "additionalProperties": false,
            "required": ["obfuscated"],
            "properties": {
                "obfuscated": { "type": "string", "minLength": 1, "maxLength": 512 },
                "extends": { "type": "string", "maxLength": 4096 },
                "kind": { "$ref": "#/definitions/classKind" },
                "dex": { "type": "string", "maxLength": 4096 },
                "aidl_descriptor": { "type": "string", "maxLength": 4096 },
                "anchors": {
                    "type": "array",
                    "maxItems": 1000,
                    "items": { "type": "string", "maxLength": 4096 }
                },
                "methods": {
                    "type": "object",
                    "maxProperties": 5000,
                    "propertyNames": { "not": { "enum": ["__proto__", "constructor", "prototype"] } },
                    "additionalProperties": { "$ref": "#/definitions/methodMapValue" }
                },
                "fields": {
                    "type": "object",
                    "maxProperties": 5000,
                    "propertyNames": { "not": { "enum": ["__proto__", "constructor", "prototype"] } },
                    "additionalProperties": { "$ref": "#/definitions/fieldEntry" }
                },
                "source": { "type": "string", "maxLength": 4096 },
                "confidence": { "$ref": "#/definitions/confidence" }
            }
        }
    }
}
